# MongoDB Atlas connection string (create a free cluster at mongodb.com/atlas)
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/social-app?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string_here

# Secret key used to sign JWT tokens — use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the server runs on (Render will set this automatically in production)
PORT=5000

# Comma separated list of allowed frontend origins for CORS
# Example: https://your-app.vercel.app,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
